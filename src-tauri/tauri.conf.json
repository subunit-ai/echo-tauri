{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "echo",
  "version": "0.5.11",
  "identifier": "ai.subunit.echo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "echo",
        "width": 800,
        "height": 600,
        "minWidth": 720,
        "minHeight": 540,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; media-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://*.sentry.io https://transcribe.subunit.ai wss://transcribe.subunit.ai"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/subunit-ai/echo-tauri/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1MjU2QzFERTNFNEQ0RTEKUldUaDFPVGpIV3dsMVlXVGdtblhWWi94ZGxGRGFBcnJLVy9IVUVCLzViamNtd3NRQi9aZncyRGcK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
